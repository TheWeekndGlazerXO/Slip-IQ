{
  "appId": "com.slipiq.app",
  "appName": "Slip IQ",
  "webDir": "public",
"server": {
  "hostname": "slipiq.net",
  "androidScheme": "https",
  "cleartext": false
},
  "ios": {
    "contentInset": "automatic",
    "backgroundColor": "#04080f",
    "allowsLinkPreview": false,
    "scrollEnabled": false,
    "startPage": "home.html"
  },
  "android": {
    "startPage": "home.html"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#04080f",
      "iosSpinnerStyle": "small",
      "spinnerColor": "#00c8f8",
      "showSpinner": false
    }
  }
}